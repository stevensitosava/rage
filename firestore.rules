rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // PUBLIC READ — anyone can read published content
    // WRITE — only authenticated admins

    match /flavors/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /about/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /contact/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /pages/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
