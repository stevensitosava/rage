rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // PUBLIC READ — anyone can read published content
    // WRITE — only authenticated admins

    match /flavors/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /about/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /contact/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /pages/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Admin users allowlist — readable by any authenticated user (for auth check),
    // writable only via Firebase Console (never from client code)
    match /admin_users/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Visit counter — public can increment, only authenticated users can read
    match /site_visits/{docId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasOnly(['count'])
                    && request.resource.data.count is int;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count']);
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
